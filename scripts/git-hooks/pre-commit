#!/bin/bash
# 预提交检查：防止敏感信息提交到 Git
# 安装：ln -sf ../../.git/hooks/pre-commit .git/hooks/pre-commit

set -e

RED='\033[0;31m'
NC='\033[0m'

# 1. 检查 config.yaml 是否被暂存（删除除外，不允许新增/修改）
if git diff --cached --name-only --diff-filter=ACMR | grep -q '^config\.yaml$'; then
  echo -e "${RED}❌ 禁止提交 config.yaml！此文件包含 API Key，已被 .gitignore 排除。${NC}"
  echo "   如需添加新配置项，请修改 config.example.yaml（不含真实 key）。"
  exit 1
fi

# 2. 扫描暂存文件的新增行中是否包含疑似真实密钥（只扫 + 开头的行，排除占位符）
PATTERNS=(
  'sk-[a-zA-Z0-9]{20,}'           # sk- 格式的 API key（排除短的占位符）
)

STAGED_FILES=$(git diff --cached --name-only)
if [ -n "$STAGED_FILES" ]; then
  for pattern in "${PATTERNS[@]}"; do
    # 只检查新增行（+开头），排除占位符和示例值
    MATCHES=$(git diff --cached -U0 | grep '^+' | grep -v '^+++' | grep -v 'sk-xxx\|sk-your-\|sk-api-\|placeholder\|example\|your-api-key' | grep -E "$pattern" || true)
    if [ -n "$MATCHES" ]; then
      echo -e "${RED}⚠️  发现疑似真实 API Key，提交被阻止。${NC}"
      echo "   如果这是占位符，请在模式中加入排除规则。"
      echo "$MATCHES" | head -5
      exit 1
    fi
  done
fi

echo "✅ 敏感信息检查通过"
